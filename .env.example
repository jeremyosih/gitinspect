# API key injected server-side for "OpenCode Free" tier requests.
# The Nitro proxy at /api/proxy reads this and attaches it to outgoing requests
# so the key never appears in the client bundle.
FIREWORKS_API_KEY=fw-your-fireworks-api-key-here

# GitHub App client secret for OAuth token exchange.
# The Nitro proxy at /api/github-token injects this server-side.
GITHUB_CLIENT_SECRET=your-github-app-client-secret
