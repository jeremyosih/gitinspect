# API key injected server-side for "OpenCode Free" tier requests.
# The TanStack Start server route at /api/proxy reads this and attaches it to
# outgoing requests so the key never appears in the client bundle.
FIREWORKS_API_KEY=fw-your-fireworks-api-key-here

# Optional feedback-to-GitHub integration for /api/feedback.
FEEDBACK_GITHUB_TOKEN=github_pat_your_feedback_token_here
FEEDBACK_GITHUB_OWNER=your-org-or-user
FEEDBACK_GITHUB_REPO=your-main-app-repo
