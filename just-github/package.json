{
  "name": "just-github",
  "version": "0.1.0",
  "description": "An fs-like API for reading files from GitHub repositories — without cloning",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
